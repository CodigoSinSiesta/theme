---
import DocsLayout from '../layouts/DocsLayout.astro';
const base = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

const components = [
  { href: '/components/eyebrow',         name: 'Eyebrow',        desc: 'Barra horizontal 24×2px + texto mono uppercase. Acompaña el header de cada slide.' },
  { href: '/components/callout',         name: 'Callout',        desc: 'Aside box con kind semántico (info/ok/warn/err). Border-left + icono + título + body.' },
  { href: '/components/toolcard',        name: 'ToolCard',       desc: 'Card con accent bar + icon box 42×42 + tag pill + meta strip opcional.' },
  { href: '/components/terminal-line',   name: 'TerminalLine',   desc: 'Una línea individual de terminal con tipos cmd/out/ok/err/comment.' },
  { href: '/components/terminal-window', name: 'TerminalWindow', desc: 'Caja Mac-style (titlebar + 3 dots) que envuelve TerminalLine.' },
  { href: '/components/qrcode',          name: 'QRCode',         desc: 'Placeholder 21×21 determinístico (NO escaneable). Decoración para slides finales.' }
];

const shells = [
  { href: '/slides/shell',     name: 'SlideShell',     desc: 'Wrapper base con .swiper-slide + 7 bg presets (azul / identidad / verde / cierre / lila / naranja / none) + slot.' },
  { href: '/slides/hero',      name: 'SlideHero',      desc: 'Portada completa: eyebrow + title con highlight + subtitle + intro + tools + author card + 3 orbs.' },
  { href: '/slides/toc',       name: 'SlideTOC',       desc: 'Agenda con chapter cards en grid 2-cols. Estados current/past/future.' },
  { href: '/slides/terminal',  name: 'SlideTerminal',  desc: 'Hands-on con TerminalWindow + narración paso a paso lateral + Pro tip Callout.' },
  { href: '/slides/resources', name: 'SlideResources', desc: 'Cierre con takeaways grid arriba + links + QR placeholder abajo.' },
  { href: '/slides/statement', name: 'SlideStatement', desc: 'Idea grande + palabra-highlight gradient + atribución. Para tesis y rotundidades.' },
  { href: '/slides/compare',   name: 'SlideCompare',   desc: 'A vs B do/don\'t. Cards rojo + verde con accent semántico configurable.' },
  { href: '/slides/stats',     name: 'SlideStats',     desc: 'Big numbers en grid con trend autocoloreado (↑ ok / ↓ err) + callout opcional.' },
  { href: '/slides/diagram',   name: 'SlideDiagram',   desc: 'Cajas + flechas SVG curvadas + leyenda. Coords absolutas en viewBox 1180×460.' },
  { href: '/slides/code',      name: 'SlideCode',      desc: 'Window mac-style con código + gutter + columna de notas L{n} + callout.' },
  { href: '/slides/list',      name: 'SlideList',      desc: 'Items numerados en grid 2-4 columnas. Patrón "12 reglas" / checklist.' },
  { href: '/slides/pattern-grid',   name: 'SlidePatternGrid',   desc: 'Cards con mini-SVGs de patrones agénticos (chain / fan-out / fan-in / orchestrator-workers / eval-loop).' },
  { href: '/slides/decision-table', name: 'SlideDecisionTable', desc: 'Tabla cuadrante glass con highlight-row + celdas auto-coloreadas (✓ / ✕ / ~) + reglas prácticas.' },
  { href: '/slides/pipeline',       name: 'SlidePipeline',      desc: 'Pipeline horizontal de pasos numerados separados por →. Soporta Heroicons SVG + paso success final.' },
  { href: '/slides/handson',        name: 'SlideHandsOn',       desc: 'Workshop pill ⚡ N min + pasos numerados + bloques shell. Highlight de "current step" para presentación en vivo.' },
  { href: '/slides/section',        name: 'SlideSection',       desc: 'Divisor de capítulo: número gigante con gradiente + label parte·sección + h1 + hint.' },
  { href: '/slides/quote',          name: 'SlideQuote',         desc: 'Aforismo de cierre: 💬 + eyebrow + cita gigante + atribución entre rules.' },
  { href: '/slides/whoami',         name: 'SlideWhoAmI',        desc: 'Speaker card: avatar circular + bio + tags + handles + callout opcional.' },
  { href: '/slides/tools-grid',     name: 'SlideToolsGrid',     desc: 'Header + grid 3×2 de ToolCards (composición canónica del kit V4).' },
  { href: '/slides/equation',       name: 'SlideEquation',      desc: 'Slide-tesis tipo ecuación: term + op + term = outcome (Agent = Model + Harness).' },
  { href: '/slides/layer-stack',    name: 'SlideLayerStack',    desc: 'Capas horizontales tipo OS-stack (kernel/runtime/app) con tinted backgrounds.' },
  { href: '/slides/nested-eras',    name: 'SlideNestedEras',    desc: 'Anillos concéntricos matryoshka — el más interno con gradient violeta + glow.' },
  { href: '/slides/code-compare',   name: 'SlideCodeCompare',   desc: 'Dos paneles de código lado-a-lado con badge flotante. Highlight ligero ts/js/py/shell.' },
  { href: '/slides/accent-cards',   name: 'SlideAccentCards',   desc: 'Grid de cards con border-top de color custom por card. MCP primitives, capas, etc.' },
  { href: '/slides/triada',         name: 'SlideTriada',        desc: 'Knowledge-graph triada: card vertical con N filas (NODE/EDGE/TRIPLE) + chips violeta.' },
  { href: '/slides/didactic',       name: 'SlideDidactic',      desc: 'Definition + Analogía + Examples — estructura pedagógica de 3 columnas.' }
];
---

<DocsLayout title="theme · @codigosinsiesta · docs">
  <div class="docs-page-header">
    <span class="docs-page-eyebrow">v0.7.0 · dark blueprint</span>
    <h1 class="docs-page-title">@codigosinsiesta/theme</h1>
    <p class="docs-page-desc">
      Sistema de diseño V4 compartido entre las presentaciones de Código Sin Siesta.
      Tokens CSS + chrome global + Tailwind preset + 6 componentes-átomo Svelte + <strong>26 slide-shells canónicos</strong> cubriendo el kit V4 completo + los 16 patrones del audit V5 (Tier 1/2/3) + 4 layouts editoriales residuales (Section / Quote / WhoAmI / ToolsGrid). Brand assets oficiales (búho + wordmark + 13 Heroicons). Mismo stack Astro 5 + Svelte 5 + Tailwind 4 que los decks consumidores.
    </p>
  </div>

  <section class="docs-section">
    <h2>Empieza aquí</h2>
    <p>
      Instala el theme en tu deck (Astro o Svelte) — basta con la dependencia git URL hasta que se publique en npm:
    </p>
    <div class="docs-example">
      <div class="docs-example-label">terminal</div>
      <pre class="docs-example-code"><code><span class="ctrl">$</span> pnpm add github:CodigoSinSiesta/theme</code></pre>
    </div>
    <p>
      En tu CSS global:
    </p>
    <div class="docs-example">
      <div class="docs-example-label">src/styles/global.css</div>
      <pre class="docs-example-code"><code><span class="ctrl">@import</span> <span class="str">'@codigosinsiesta/theme/all.css'</span>;</code></pre>
    </div>
  </section>

  <section class="docs-section">
    <h2>Componentes-átomo (v0.2.0+)</h2>
    <p>Primitivas reutilizables. Pásales props con el contenido y obtienes el patrón canónico del kit V4.</p>
    <div class="docs-grid">
      {components.map((c) => (
        <a class="docs-card" href={base + c.href}>
          <span class="docs-card-name">{c.name}</span>
          <span class="docs-card-desc">{c.desc}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="docs-section">
    <h2>Slide-shells canónicos · 26 layouts (v0.7.0 cierra el kit completo)</h2>
    <p>Composiciones completas de slide. Pásales data y obtienes un slide pixel-perfect. Los layouts cubren los 15 slide-types del kit V4, los 16 patrones del audit V5, y 4 layouts editoriales residuales.</p>
    <div class="docs-grid">
      {shells.map((s) => (
        <a class="docs-card" href={base + s.href}>
          <span class="docs-card-name">{s.name}</span>
          <span class="docs-card-desc">{s.desc}</span>
        </a>
      ))}
    </div>
  </section>
</DocsLayout>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .docs-card {
    background: var(--color-fondo-alt);
    border: 1px solid var(--color-borde);
    border-radius: 10px;
    padding: 18px 22px;
    text-decoration: none;
    transition: border-color 150ms ease-out, transform 150ms ease-out, box-shadow 150ms ease-out;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .docs-card:hover {
    border-color: var(--color-electrico);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.15);
  }
  .docs-card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--color-tinta);
  }
  .docs-card-desc {
    font-size: 13px;
    color: var(--color-tinta3);
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .docs-grid { grid-template-columns: 1fr; }
  }
</style>
