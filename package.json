      "require": "./src/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./chrome.css": "./src/chrome.css",
    "./all.css": "./src/all.css",
    "./tailwind.preset.js": "./src/tailwind.preset.js"
  },
  "keywords": [
    "design-system",
    "presentations",
    "astro",
    "svelte",
    "tailwind",
    "css-tokens",
